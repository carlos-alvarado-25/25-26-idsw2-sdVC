@startuml abrirExamenes

skinparam linetype polyline

state abrirExamenes as "abrirExamenes()" {

state " " as MostrandoLista
state " " as FiltrandoLista

[*] -[#green]-> MostrandoLista 
note on link
<b>Administrador</b> solicita abrir exámenes
end note    

MostrandoLista -[#green]-> FiltrandoLista
note on link
<b>Sistema</b> presenta lista de exámenes
• Código, asignatura, fecha programada
• Aula asignada, profesor responsable
• Permite solicitar filtrar lista
• Permite solicitar crear examen nuevo
• Permite solicitar eliminar examen
• Permite solicitar editar examen
end note

FiltrandoLista -[#green]-> FiltrandoLista
note on link
<b>Administrador</b> solicita filtrar lista
<b>Sistema</b> presenta lista filtrada
end note

FiltrandoLista -[#green]-> [*]
note on link
<b>Administrador</b> solicita una de las opciones
end note
}

abrirExamenes -[#green]-> EXAMEN_ABIERTO
note on link
editarExamen()
end note

abrirExamenes -[#green]-> EXAMEN_ABIERTO
note on link
crearExamen()
end note

abrirExamenes -[#green]-> EXAMENES_ABIERTO
note on link
eliminarExamen()
end note

abrirExamenes -[#green]-> SISTEMA_DISPONIBLE
note on link
completarGestion()
end note

@enduml