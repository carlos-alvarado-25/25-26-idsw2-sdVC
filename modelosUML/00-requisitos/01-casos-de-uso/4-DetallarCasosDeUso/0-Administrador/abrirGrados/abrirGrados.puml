@startuml abrirGrados

skinparam linetype polyline

state abrirGrados as "abrirGrados()" {

state " " as MostrandoLista
state " " as FiltrandoLista

[*] -[#green]-> MostrandoLista 
note on link
<b>Administrador</b> solicita abrir grados
end note    

MostrandoLista -[#green]-> FiltrandoLista
note on link
<b>Sistema</b> presenta lista de grados
• Código, nombre, descripción de cada grado
• Permite solicitar filtrar lista
• Permite solicitar crear grado nuevo
• Permite solicitar eliminar grado
• Permite solicitar editar grado
• Permite solicitar importar grados
end note

FiltrandoLista -[#green]-> FiltrandoLista
note on link
<b>Administrador</b> solicita filtrar lista
<b>Sistema</b> presenta lista filtrada
end note

FiltrandoLista -[#green]-> [*]
note on link
<b>Administrador</b> solicita una de las opciones
end note
}

abrirGrados -[#green]-> GRADO_ABIERTO
note on link
editarGrado()
end note

abrirGrados -[#green]-> GRADO_ABIERTO
note on link
crearGrado()
end note

abrirGrados -[#green]-> GRADOS_ABIERTO
note on link
eliminarGrado()
end note

abrirGrados -[#green]-> GRADOS_ABIERTO
note on link
importarGrados()
end note

abrirGrados -[#green]-> SISTEMA_DISPONIBLE
note on link
completarGestion()
end note

@enduml