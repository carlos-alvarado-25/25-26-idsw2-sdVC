state "ALUMNOS_ABIERTO" as ListAlumnos
state "ALUMNO_ABIERTO" as EditAlumno

state "CALENDARIO_GENERADO" as Generacion
state "CALENDARIO_ABIERTO" as Consulta

[*] --> NoAuth
